{
  "name": "@joshwooding/vite-plugin-react-docgen-typescript-monorepo",
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "keywords": [
    "vite",
    "vite-plugin",
    "react-docgen-typescript"
  ],
  "homepage": "https://github.com/joshwooding/vite-plugin-react-docgen-typescript",
  "scripts": {
    "benchmark": "yarn build && node ./scripts/benchmark-playground.mjs",
    "benchmark:ci": "yarn build && node ./scripts/benchmark-playground.mjs --scenario playground --iterations 1 && node ./scripts/benchmark-playground.mjs --scenario large-project --iterations 1 && node ./scripts/benchmark-playground.mjs --scenario large-design-system --iterations 1",
    "benchmark:large-design-system": "yarn benchmark --scenario large-design-system",
    "benchmark:large-project": "yarn benchmark --scenario large-project",
    "benchmark:playground": "yarn benchmark --scenario playground",
    "build": "yarn workspace @joshwooding/vite-plugin-react-docgen-typescript build",
    "biome": "biome format . --write",
    "biome:check": "biome check --write --unsafe .",
    "biome:ci": "biome ci .",
    "test": "vitest",
    "typecheck": "yarn workspace @joshwooding/vite-plugin-react-docgen-typescript typecheck",
    "storybook": "yarn workspace playground storybook"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.25.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^18.0.0",
    "typescript": "5.6.X",
    "unbuild": "^3.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "resolutions": {
    "@joshwooding/vite-plugin-react-docgen-typescript": "workspace:*",
    "esbuild": "^0.24.0"
  },
  "packageManager": "yarn@4.13.0"
}
