{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "files": {
    "includes": ["**", "!**/package.json"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      }
    },
    "includes": ["**", "!**/dist", "!**/*.tsx"]
  },
  "formatter": {
    "enabled": true,
    "includes": ["**", "!**/dist"],
    "indentStyle": "space"
  },
  "overrides": [
    {
      "includes": ["**/__tests__/**"],
      "linter": {
        "rules": {
          "complexity": { "noForEach": "off" }
        }
      }
    }
  ]
}
