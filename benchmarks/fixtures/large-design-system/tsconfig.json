{
  "include": ["src/**/*"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@composites/*": ["src/composites/*"],
      "@design/*": ["src/*"],
      "@feedback/*": ["src/feedback/*"],
      "@forms/*": ["src/forms/*"],
      "@primitives/*": ["src/primitives/*"],
      "@tokens/*": ["src/tokens/*"]
    }
  }
}
